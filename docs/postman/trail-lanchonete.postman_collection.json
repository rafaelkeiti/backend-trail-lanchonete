    {
      "name": "Pedidos e Pagamento",
      "item": [
        {
          "name": "T07 - Cliente cria pedido válido",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('pedidoId', json.id);",
                  "pm.test('status inicial correto', function () { pm.expect(json.status).to.eql('AGUARDANDO_PAGAMENTO'); });",
                  "pm.test('canal registrado', function () { pm.expect(json.canalPedido).to.eql('APP'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{clienteToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"canalPedido\": \"APP\",\n  \"unidadeId\": \"{{unidadeId}}\",\n  \"itens\": [\n    {\n      \"produtoId\": \"{{produtoId}}\",\n      \"quantidade\": 1\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/pedidos"
          }
        },
        {
          "name": "T08 - Administrador filtra pedidos por canal",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "const pedidos = pm.response.json();",
                  "pm.test('retorna pedidos do canal APP', function () {",
                  "  pm.expect(pedidos).to.be.an('array').that.is.not.empty;",
                  "  pm.expect(pedidos.every(function (pedido) { return pedido.canalPedido === 'APP'; })).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
