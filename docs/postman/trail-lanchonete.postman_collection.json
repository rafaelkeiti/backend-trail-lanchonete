      "name": "Auth",
      "item": [
        {
          "name": "T01 - Cliente realiza login válido",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('clienteToken', json.accessToken);",
                  "pm.test('retorna accessToken', function () { pm.expect(json.accessToken).to.be.a('string'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cliente@exemplo.com\",\n  \"senha\": \"Senha@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
